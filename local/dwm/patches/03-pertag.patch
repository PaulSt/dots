@@ -1517,13 +1526,33 @@ setfullscreen(Client *c, int fullscreen)
 	}
 }
 
+unsigned int
+tagindex(unsigned int tagset)
+{
+	unsigned int i;
+
+	tagset &= TAGMASK;
+	if (!tagset || tagset == TAGMASK || (tagset & (tagset - 1)))
+		return 0; /* shared slot for multi-tag / all-tags views */
+
+	for (i = 0; i < LENGTH(tags); i++)
+		if (tagset == (1U << i))
+			return i + 1;
+	return 0;
+}
+
 void
 setlayout(const Arg *arg)
 {
+	unsigned int idx = tagindex(selmon->tagset[selmon->seltags]);
+
 	if (!arg || !arg->v || arg->v != selmon->lt[selmon->sellt])
 		selmon->sellt ^= 1;
 	if (arg && arg->v)
 		selmon->lt[selmon->sellt] = (Layout *)arg->v;
+	selmon->tagsellt[idx] = selmon->sellt;
+	selmon->taglt[idx][0] = selmon->lt[0];
+	selmon->taglt[idx][1] = selmon->lt[1];
 	strncpy(selmon->ltsymbol, selmon->lt[selmon->sellt]->symbol, sizeof selmon->ltsymbol);
 	if (selmon->sel)
 		arrange(selmon);
@@ -1764,10 +1793,15 @@ toggletag(const Arg *arg)
 void
 toggleview(const Arg *arg)
 {
+	unsigned int idx;
 	unsigned int newtagset = selmon->tagset[selmon->seltags] ^ (arg->ui & TAGMASK);
 
 	if (newtagset) {
 		selmon->tagset[selmon->seltags] = newtagset;
+		idx = tagindex(newtagset);
+		selmon->sellt = selmon->tagsellt[idx];
+		selmon->lt[0] = selmon->taglt[idx][0];
+		selmon->lt[1] = selmon->taglt[idx][1];
 		focus(NULL);
 		arrange(selmon);
 	}
@@ -2064,11 +2098,17 @@ updatewmhints(Client *c)
 void
 view(const Arg *arg)
 {
+	unsigned int idx;
+
 	if ((arg->ui & TAGMASK) == selmon->tagset[selmon->seltags])
 		return;
 	selmon->seltags ^= 1; /* toggle sel tagset */
 	if (arg->ui & TAGMASK)
 		selmon->tagset[selmon->seltags] = arg->ui & TAGMASK;
+	idx = tagindex(selmon->tagset[selmon->seltags]);
+	selmon->sellt = selmon->tagsellt[idx];
+	selmon->lt[0] = selmon->taglt[idx][0];
+	selmon->lt[1] = selmon->taglt[idx][1];
 	focus(NULL);
 	arrange(selmon);
 }
